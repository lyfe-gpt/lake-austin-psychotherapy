      }
    },
    {
      "@type": "Question",
      "name": "Can I do anxiety treatment via telehealth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. EMDR, CBT, and talk therapy for anxiety are all available via secure, HIPAA-compliant video anywhere in Texas. Multiple peer-reviewed studies confirm telehealth therapy achieves outcomes equivalent to in-person care for anxiety. You need to be physically located in Texas during sessions."
      }
    },
    {
      "@type": "Question",
      "name": "How long does anxiety treatment take?",
